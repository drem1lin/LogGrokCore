<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:logGrokCore="clr-namespace:LogGrokCore"
                    xmlns:loc="clr-namespace:LogGrokCore.Localization"
                    xmlns:localControls="clr-namespace:LogGrokCore.Controls"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:listControls="clr-namespace:LogGrokCore.Controls.ListControls"
                    mc:Ignorable="d">

    <localControls:IsNullToVisibilityConverter x:Key="IsNullToVisibilityConverter"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <Style x:Key="FilterContextMenuItem"
           TargetType="MenuItem"
           BasedOn="{StaticResource MahApps.Styles.MenuItem}"
           d:DataContext="{d:DesignInstance Type=logGrokCore:LogViewModel, IsDesignTimeCreatable=False}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=ItemsSource}"
                         Value="{x:Null}">
                <DataTrigger.Setters>
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger.Setters>
            </DataTrigger>
            <DataTrigger
                Binding="{Binding CanFilter}"
                Value="False">
                <DataTrigger.Setters>
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger.Setters>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <ContextMenu
        d:DataContext="{d:DesignInstance Type={x:Type listControls:ListView}, IsDesignTimeCreatable=False}"
        x:Key="LogViewContextMenu"
        DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
        <MenuItem Command="logGrokCore:RoutedCommands.CopyToClipboard"
                  Header="{loc:Loc Context_Copy}"
                  Visibility="{Binding RelativeSource={RelativeSource Self},
                                              Path=IsEnabled,
                                              Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Kind="ContentCopy" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="logGrokCore:RoutedCommands.CopyToClipboardFormatted"
                  Header="{loc:Loc Context_CopyFormattedJson}"
                  InputGestureText="Ctrl+Shift+C"
                  Visibility="{Binding RelativeSource={RelativeSource Self},
                                              Path=IsEnabled,
                                              Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Kind="CodeJson" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="logGrokCore:RoutedCommands.ToggleMarks"
                  Header="{loc:Loc Context_ToggleMarks}"
                  Visibility="{Binding RelativeSource={RelativeSource Self},
                                              Path=IsEnabled,
                                              Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" 
                    Kind="CheckboxMultipleBlankCircle" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="logGrokCore:RoutedCommands.SearchText"
                            CommandParameter="{Binding PlacementTarget.SelectedText,
                            RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"

                  Visibility="{Binding RelativeSource={RelativeSource Self},
                                              Path=IsEnabled,
                                              Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.Header>
                <MultiBinding Converter="{localControls:FormatTextMulti}">
                    <Binding Path="PlacementTarget.SelectedText"
                             RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}" />
                    <Binding Path="[Context_SearchSelection]"
                             Source="{x:Static loc:TranslationSource.Instance}" />
                </MultiBinding>
            </MenuItem.Header>
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Kind="Magnify" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{loc:Loc Context_Exclude}" Style="{StaticResource FilterContextMenuItem}"
                  DataContext="{Binding DataContext}"
                  d:DataContext="{d:DesignInstance Type={x:Type logGrokCore:LogViewModel}, IsDesignTimeCreatable=False}">
            <MenuItem.ItemsSource>
                <MultiBinding
                    Converter="{localControls:MetaInfoToMenuItemsConverter}">
                    <Binding Path="MetaInformation" />
                    <Binding Path="ExcludeCommand" />
                    <Binding Path="SelectedItems" />
                </MultiBinding>
            </MenuItem.ItemsSource>
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Kind="FilterMinusOutline" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{loc:Loc Context_ExcludeAllBut}" Style="{StaticResource FilterContextMenuItem}"
                  DataContext="{Binding DataContext}"
                  d:DataContext="{d:DesignInstance Type={x:Type logGrokCore:LogViewModel}, IsDesignTimeCreatable=False}">
            <MenuItem.ItemsSource>
                <MultiBinding
                    Converter="{localControls:MetaInfoToMenuItemsConverter}">
                    <Binding Path="MetaInformation" />
                    <Binding Path="ExcludeAllButCommand" />
                    <Binding Path="SelectedItems" />
                </MultiBinding>
            </MenuItem.ItemsSource>
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Kind="FilterPlusOutline" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="{x:Static logGrokCore:RoutedCommands.ClearFilters}"
                  Header="{loc:Loc Context_ClearFilters}"
                  Visibility="{Binding RelativeSource={RelativeSource Self},
                                              Path=IsEnabled,
                                              Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem.Icon>
                <iconPacks:PackIconMaterial
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Kind="FilterRemoveOutline" />
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{loc:Loc Context_Folding}"
                  DataContext="{Binding PlacementTarget.FoldingManager,
                            RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}}"
              Visibility="{Binding
                            Converter={StaticResource IsNullToVisibilityConverter},
                            FallbackValue={x:Static Visibility.Collapsed}}">
            <MenuItem Header="{loc:Loc Context_ExpandRecursively}" Command="{Binding ExpandRecursivelyCommand}"/>
            <MenuItem Header="{loc:Loc Context_CollapseRecursively}" Command="{Binding CollapseRecursivelyCommand}"/>
            <MenuItem Header="{loc:Loc Context_ResetToDefault}" Command="{Binding ResetToDefaultCommand}"/>
            <MenuItem Header="{loc:Loc Context_ExpandAll}" Command="{Binding ExpandAllCommand}"/>
            <MenuItem Header="{loc:Loc Context_CollapseAll}" Command="{Binding CollapseAllCommand}"/>
            <MenuItem Header="{loc:Loc Context_ResetAll}" Command="{Binding ResetAllToDefaultCommand}"/>
        </MenuItem>
    </ContextMenu>
</ResourceDictionary>